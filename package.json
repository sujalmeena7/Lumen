{
  "name": "dynamic-cost-aware-ai-router",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:gateway": "pnpm --filter @router/gateway dev",
    "dev:web": "pnpm --filter @router/web dev",
    "db:generate": "pnpm --filter @router/db generate",
    "db:migrate": "pnpm --filter @router/db migrate",
    "db:seed": "pnpm --filter @router/db seed",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@vitest/coverage-v8": "2.1.4",
    "prettier": "3.3.3",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@prisma/client", "@prisma/engines", "prisma", "sharp", "unrs-resolver"]
  }
}
