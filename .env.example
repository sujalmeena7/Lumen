# ---- Gateway ----
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0
NODE_ENV=development

# ---- Web Dashboard ----
GATEWAY_INTERNAL_URL=http://localhost:8080
SESSION_SECRET=super-secret-iron-session-password-at-least-32-chars
# Shared secret allowing the Next.js dashboard (server-side only) to call the
# gateway on a logged-in user's behalf without a per-workspace gateway key.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must be set identically here and in apps/web/.env.local. Never expose to browsers.
INTERNAL_SERVICE_TOKEN=

# ---- Postgres ----
DATABASE_URL=postgresql://router:router@localhost:5432/router?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Credential envelope encryption (KMS-ready) ----
# 32-byte base64 master key. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY=

# ---- Rate limiting ----
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SEC=60

# ---- Provider API base URLs (override for testing/mocks) ----
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- Routing baseline (Money Saved metric) ----
PREMIUM_BASELINE_MODEL=gpt-4o

# ---- Razorpay billing (Task 15) ----
# Test-mode key id/secret from the Razorpay Dashboard, and the webhook signing secret.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Static USD->INR conversion rate used to convert accrued usage cost (computed
# in USD) into the INR amount charged via Razorpay. Refresh periodically from
# a live FX rate in production.
USD_TO_INR_RATE=83
